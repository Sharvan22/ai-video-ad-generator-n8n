    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a professional marketing strategist.\\n\\nBased on the following information:\\n\\nWebsite Information:\\n{{ $node[\"HTTP Request\"].json.data }}\\n\\n\\nMarket Research:\\n{{ $node[\"Tavily Research\"].json.results }}\\n\\nCreate:\\n\\n1) A powerful 5-second hook for a video advertisement.\\n2) A storyboard with exactly 4 scenes.\\nEach scene should be 8 seconds long.\\n\\nIMPORTANT:\\nReturn ONLY valid JSON.\\nDo NOT include explanations.\\nDo NOT include markdown.\\nDo NOT include text outside JSON.\\n\\nFormat exactly like this:\\n\\n{\\n  \"hook\": \"string\",\\n  \"scenes\": [\\n    {\\n      \"scene_number\": 1,\\n      \"description\": \"string\",\\n      \"visuals\": \"string\"\\n    },\\n    {\\n      \"scene_number\": 2,\\n      \"description\": \"string\",\\n      \"visuals\": \"string\"\\n    },\\n    {\\n      \"scene_number\": 3,\\n      \"description\": \"string\",\\n      \"visuals\": \"string\"\\n    },\\n    {\\n      \"scene_number\": 4,\\n      \"description\": \"string\",\\n      \"visuals\": \"string\"\\n    }\\n  ]\\n}\\n",
        "batching": {}
