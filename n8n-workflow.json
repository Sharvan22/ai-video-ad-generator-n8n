    {
      "parameters": {
        "jsCode": "// Get first incoming item\nconst input = $input.first().json;\n\n// If scenes is already an array\nif (Array.isArray(input.scenes)) {\n  return input.scenes.map(scene => ({\n    json: scene\n  }));\n}\n\n// If scenes is a string\nif (typeof input.scenes === \"string\") {\n  const parsedScenes = JSON.parse(input.scenes);\n  return parsedScenes.map(scene => ({\n    json: scene\n  }));\n}\n\n// Fallback (debug)\nreturn [{\n  json: {\n    error: \"Scenes not found\",\n    received: input\n  }\n}];\n"
      },
      "id": "050cb440-d391-4bf7-b5f9-1c8400653a6a",
