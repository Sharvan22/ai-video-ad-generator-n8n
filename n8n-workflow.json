    {
      "parameters": {
        "jsCode": "const inputItems = $input.all();\nlet rawText = inputItems[0].json.text;\n\n// Remove ```json and ``` wrappers\nrawText = rawText\n  .replace(/```json/g, '')\n  .replace(/```/g, '')\n  .trim();\n\nconst parsed = JSON.parse(rawText);\n\nreturn [\n  {\n    json: parsed\n  }\n];\n"
      },
